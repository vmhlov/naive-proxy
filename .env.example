# Public IP or FQDN that resolves to this host. nip.io is fine for IP-only setups.
DOMAIN=1.2.3.4.nip.io

# Contact e-mail for Let's Encrypt notifications. Use a real address.
EMAIL=admin@example.com

# Proxy Basic-Auth credentials.
# Allowed characters: letters, digits, and any of `-_.~+=!*()`.
# Forbidden: `:` `@` `/` `\` whitespace and quotes (would break Caddyfile / URL).
PROXY_USER=username
PROXY_PASS=ChangeMe_Str0ng!Pass

# Optional. Container timezone, e.g. Europe/Moscow, America/New_York.
TZ=Etc/UTC
