# Caddyfile template used by setup.sh.
# Five placeholders (DOMAIN, EMAIL, PROXY_USER, PROXY_PASS,
# PROBE_RESISTANCE) — wrapped in double curly braces — are substituted
# at deploy time. Do not edit the rendered Caddyfile by hand; edit this
# template and re-run setup.sh.

{
	admin off
	log {
		output stdout
		level INFO
	}
	servers :443 {
		protocols h1 h2 h3
	}
}

:80 {
	redir https://{host}{uri} permanent
}

:443, {{DOMAIN}} {
	tls {{EMAIL}}
	route {
		forward_proxy {
			basic_auth {{PROXY_USER}} {{PROXY_PASS}}
			hide_ip
			hide_via
			probe_resistance {{PROBE_RESISTANCE}}
		}
		respond "Hello, world!"
	}
}
